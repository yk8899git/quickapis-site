      <script type="application/json" id="_SSI_DATA_officialHeader">{"header":[{"title":"航拍无人机","display_type":"single-link","link":"/camera-drones","link_type":"relative-path"},{"title":"手持摄影设备","display_type":"single-link","link":"/handheld","link_type":"relative-path"},{"title":"储能及家居科技","display_type":"simple-dropdown","link":"","link_type":"relative-path","nav_simple_dropdowns":[{"title":"户外电源","link":"/portable-power-station","link_type":"relative-path"},{"title":"清洁机器人","link":"https://www.romo.tech","link_type":"absolute-path"}]},{"title":"商用产品及方案","display_type":"simple-dropdown","link":"","link_type":"relative-path","nav_simple_dropdowns":[{"title":"行业应用","link":"https://enterprise.dji.com","link_type":"absolute-path"},{"title":"农业应用","link":"https://ag.dji.com","link_type":"absolute-path"},{"title":"运载应用","link":"delivery","link_type":"relative-path"},{"title":"教育应用","link":"/products/steam","link_type":"relative-path"}]},{"title":"探索精彩","display_type":"simple-dropdown","link":"","link_type":"relative-path","nav_simple_dropdowns":[{"title":"关于我们","link":"company","link_type":"relative-path"},{"title":"天空之城","link":"https://www.skypixel.com/","link_type":"absolute-path"},{"title":"大疆社区","link":"https://bbs.dji.com/","link_type":"absolute-path"},{"title":"媒体中心","link":"media-center","link_type":"relative-path"},{"title":"官方周边","link":"https://www.dji.com/cn/souvenir","link_type":"absolute-path"},{"title":"招聘精英","link":"https://we.dji.com/","link_type":"absolute-path"}]},{"title":"服务与支持","display_type":"single-link","link":"/support","link_type":"relative-path"},{"title":"购买渠道","display_type":"single-link","link":"/where-to-buy/retail-stores","link_type":"relative-path"}],"asyncLoad":true,"language":"zh-CN","country":"CN","mobileMode":false,"env":{"server_env":"prod","ga_id":"UA-43055594-1","withPathProject":["enterprise","ag","auto"]},"translation":{"login-m-title":{"en":"Log in to DJI","zh-CN":"登录大疆"},"meta.default.description":{"en":"DJI technology empowers us to see the future of possible. Learn about our consumer drones like DJI Mavic 3 Pro, DJI Mini 4 Pro, DJI Air 3S, DJI Flip; handheld products like Osmo Action 6, Osmo Mobile 8, Osmo Nano, DJI Mic 3, Osmo 360, Osmo Pocket 3, that capture smooth photos and videos; audio products like DJI Mic Mini for wireless recording; and professional cinematography tools like Ronin camera stabilizers and Inspire drones.","zh-CN":"DJI 大疆创新，致力于成为持续推动人类进步的科技公司。你可以了解 DJI Mavic 4 Pro、DJI Mini 5 Pro、DJI Air 3S 等航拍无人机，Osmo Action 6 等手持摄影产品，和 Ronin、Inspire 等专业影像设备。"},"meta.default.keywords":{"en":"DJI, aerial photography, aerial filming, drone, UAV, camera gimbal,quadcopter","zh-CN":"DJI，大疆，大疆官网，无人机，航拍，航拍飞行器"},"meta.default.title":{"en":"DJI - Official Website","zh-CN":"DJI 大疆创新 - 官方网站"},"subscribe-modal-email-input-error-tip":{"en":"Please enter a valid email address","zh-CN":"请输入正确的邮箱地址。"},"subscribe-modal-email-input-placeholder":{"en":"Email Address","zh-CN":"邮箱"},"subscribe-modal-info-intro":{"en":"Be the first to receive our latest product updates, newest offerings, and free product trials.","zh-CN":"第一时间获取最新产品资讯、优惠信息和免费上手体验机会。"},"subscribe-modal-info-intro.enterprise":{"en":"Subscribe to DJI Enterprise's Newsletter and receive the latest product updates, best practices, and upcoming events.","zh-CN":""},"subscribe-modal-info-privacy-note":{"en":"Your personal data will not be shared with any third-party companies. For more details, please check the <a style=\"color: #1890ff; text-decoration: none; \"target=\"_blank\" href=\"https://www.dji.com/policy\">DJI Privacy Policy</a>.","zh-CN":"您的个人信息不会透露给任何第三方公司。更多详情，请查看<a style=\"color: #1890ff; text-decoration: none; \"target=\"_blank\" href=\"https://www.dji.com/policy\">大疆隐私政策</a> 。"},"subscribe-modal-info-privacy-note-color":{"en":"<span style=\"color: rgba(0,0,0,0.45);\">\nYou can learn more about how we handle user data through the <a style=\"color: #1890ff; text-decoration: none; \"target=\"_blank\" href=\"https://www.dji.com/policy\">DJI Privacy Policy</a>.\n</span>","zh-CN":"<span style=\"color: rgba(0,0,0,0.45);\">\n您可通过<a style=\"color: #1890ff; text-decoration: none; \"target=\"_blank\" href=\"https://www.dji.com/policy\">大疆隐私政策</a>了解我们的信息管理方式。\n</span>"},"subscribe-modal-info-title":{"en":"Subscribe","zh-CN":"订阅我们"},"subscribe-modal-ok-btn":{"en":"Close","zh-CN":"关闭"},"subscribe-modal-phone-input-error-tip":{"en":"","zh-CN":"请输入正确的手机号"},"subscribe-modal-phone-input-placeholder":{"en":"","zh-CN":"请输入手机号"},"subscribe-modal-submit-btn":{"en":"Subscribe","zh-CN":"提交"},"subscribe-modal-success-intro":{"en":"Thank you for your attention and support of DJI.","zh-CN":"感谢您对大疆的关注和支持。"},"subscribe-modal-success-title":{"en":"Thanks for signing up!","zh-CN":"提交成功！"},"v1.app.downloads.hover_mask.copylink":{"en":"Copy link","zh-CN":"复制链接"},"v1.app.downloads.hover_mask.description":{"en":"Scan or visit directly","zh-CN":"请扫码或直接访问"},"v1.app.downloads.hover_mask.title":{"en":"Scan to download","zh-CN":"请扫码下载"},"v1.downloads.hover_mask.button":{"en":"Download","zh-CN":"立即下载"},"v1.downloads.message.copysuccess":{"en":"Copied","zh-CN":"已复制"},"v1.downloads.progress_mask.button":{"en":"Got It","zh-CN":"知道了"},"v1.downloads.progress_mask.description":{"en":"Check the progress on the browser’s downloads page or your device’s home screen.","zh-CN":"您可在浏览器下载页或设备桌面，实时查看进度。"},"v1.downloads.progress_mask.title":{"en":"Download started","zh-CN":"下载已开始"},"v1.downloads.rc_mask.button":{"en":"Got it","zh-CN":"知道了"},"v1.downloads.rc_mask.description":{"en":"Download not supported. Please access via browser.","zh-CN":"相关内容暂不支持下载，请前往浏览器访问。"},"v1.footer.store.point.button.link":{"en":"https://cdp-vg.djiservice.org/r/K","zh-CN":"https://cdp.djiservice.org/r/xB"},"v1.footer.store.point.button.text":{"en":"Download App","zh-CN":"立即下载"},"v1.footer.store.point.desc":{"en":"Try Virtual Flight online for free, and enjoy convenient one-stop device services.","zh-CN":"在线试飞，体验飞行乐趣；官方社区，随时交流想法；设备绑定，享一站式官方服务。"},"v1.footer.store.poi