fault.title":{"en":"DJI - Official Website","zh-CN":"DJI 大疆创新 - 官方网站"},"subscribe-modal-email-input-error-tip":{"en":"Please enter a valid email address","zh-CN":"请输入正确的邮箱地址。"},"subscribe-modal-email-input-placeholder":{"en":"Email Address","zh-CN":"邮箱"},"subscribe-modal-info-intro":{"en":"Be the first to receive our latest product updates, newest offerings, and free product trials.","zh-CN":"第一时间获取最新产品资讯、优惠信息和免费上手体验机会。"},"subscribe-modal-info-intro.enterprise":{"en":"Subscribe to DJI Enterprise's Newsletter and receive the latest product updates, best practices, and upcoming events.","zh-CN":""},"subscribe-modal-info-privacy-note":{"en":"Your personal data will not be shared with any third-party companies. For more details, please check the <a style=\"color: #1890ff; text-decoration: none; \"target=\"_blank\" href=\"https://www.dji.com/policy\">DJI Privacy Policy</a>.","zh-CN":"您的个人信息不会透露给任何第三方公司。更多详情，请查看<a style=\"color: #1890ff; text-decoration: none; \"target=\"_blank\" href=\"https://www.dji.com/policy\">大疆隐私政策</a> 。"},"subscribe-modal-info-privacy-note-color":{"en":"<span style=\"color: rgba(0,0,0,0.45);\">\nYou can learn more about how we handle user data through the <a style=\"color: #1890ff; text-decoration: none; \"target=\"_blank\" href=\"https://www.dji.com/policy\">DJI Privacy Policy</a>.\n</span>","zh-CN":"<span style=\"color: rgba(0,0,0,0.45);\">\n您可通过<a style=\"color: #1890ff; text-decoration: none; \"target=\"_blank\" href=\"https://www.dji.com/policy\">大疆隐私政策</a>了解我们的信息管理方式。\n</span>"},"subscribe-modal-info-title":{"en":"Subscribe","zh-CN":"订阅我们"},"subscribe-modal-ok-btn":{"en":"Close","zh-CN":"关闭"},"subscribe-modal-phone-input-error-tip":{"en":"","zh-CN":"请输入正确的手机号"},"subscribe-modal-phone-input-placeholder":{"en":"","zh-CN":"请输入手机号"},"subscribe-modal-submit-btn":{"en":"Subscribe","zh-CN":"提交"},"subscribe-modal-success-intro":{"en":"Thank you for your attention and support of DJI.","zh-CN":"感谢您对大疆的关注和支持。"},"subscribe-modal-success-title":{"en":"Thanks for signing up!","zh-CN":"提交成功！"},"v1.app.downloads.hover_mask.copylink":{"en":"Copy link","zh-CN":"复制链接"},"v1.app.downloads.hover_mask.description":{"en":"Scan or visit directly","zh-CN":"请扫码或直接访问"},"v1.app.downloads.hover_mask.title":{"en":"Scan to download","zh-CN":"请扫码下载"},"v1.downloads.hover_mask.button":{"en":"Download","zh-CN":"立即下载"},"v1.downloads.message.copysuccess":{"en":"Copied","zh-CN":"已复制"},"v1.downloads.progress_mask.button":{"en":"Got It","zh-CN":"知道了"},"v1.downloads.progress_mask.description":{"en":"Check the progress on the browser’s downloads page or your device’s home screen.","zh-CN":"您可在浏览器下载页或设备桌面，实时查看进度。"},"v1.downloads.progress_mask.title":{"en":"Download started","zh-CN":"下载已开始"},"v1.downloads.rc_mask.button":{"en":"Got it","zh-CN":"知道了"},"v1.downloads.rc_mask.description":{"en":"Download not supported. Please access via browser.","zh-CN":"相关内容暂不支持下载，请前往浏览器访问。"},"v1.footer.store.point.button.link":{"en":"https://cdp-vg.djiservice.org/r/K","zh-CN":"https://cdp.djiservice.org/r/xB"},"v1.footer.store.point.button.text":{"en":"Download App","zh-CN":"立即下载"},"v1.footer.store.point.desc":{"en":"Try Virtual Flight online for free, and enjoy convenient one-stop device services.","zh-CN":"在线试飞，体验飞行乐趣；官方社区，随时交流想法；设备绑定，享一站式官方服务。"},"v1.footer.store.point.title":{"en":"Only in the DJI Store App","zh-CN":"仅在大疆商城 app"},"v1.iemodal.button":{"en":"Continue Viewing","zh-CN":"仍要继续浏览"},"v1.iemodal.desc":{"en":"Internet Explorer is no longer supported. It is recommended to use other browsers.","zh-CN":"该页面不支持使用 IE 浏览器，建议您更换至其他浏览器。"},"v1.iemodal.title":{"en":"Please Change Your Browser","zh-CN":"请更换您的浏览器"},"v1.product.buy.popover.button.text":{"en":"Learn more","zh-CN":"了解更多"},"v1.product.buy.popover.desc":{"en":"1% DJI Credit Reward & 14-Day Returns","zh-CN":"享 DJI 币返点和包邮快速配送"},"v1.product.buy.popover.title":{"en":"DJI Store","zh-CN":"大疆商城专享权益"},"v2.ag.common.contact_us":{"en":"Contact us","zh-CN":"联系我们"},"v2.ag.common.contact_us.link":{"en":"https://ag.dj