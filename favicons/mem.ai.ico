<body>
  <!--
    Legacy Browser Warning
    This element is shown immediately via nomodule script for browsers that don't support ES modules.
    It can also be shown via entry.ts for legacy browsers detected by the Vite legacy plugin.
    See docs/legacy-browser-support.md for more details.
    -->
  <div id="legacy-browser-warning">
    <img src="/browser.svg" alt="" width="314" height="309" />
    <h1>Your browser needs an update</h1>
    <p>
      Mem requires a newer browser version to work properly. Please update your browser and try
      again.
    </p>
  </div>

  <!--
    Nomodule script: runs ONLY in browsers that don't support ES modules.
    This is the earliest possible detection for legacy browsers.
    -->
  <script nomodule>
    (function () {
      var warning = document.getElementById("legacy-browser-warning");
      if (warning) {
        warning.classList.add("visible");
      }
      // Set a global flag so entry.ts knows the warning is already shown
      window.__LEGACY_BROWSER_BLOCKED__ = true;
    })();
  </script>

  <!-- Display a message if JS has been disabled on the browser. -->
  <noscript>
    If you're seeing this message, that means JavaScript has been disabled on your browser. Please
    enable JS to make this app work.
  </noscript>

  <!-- App Setup -->
  <div id="root"></div>

  <!--
    Legacy Browser Check
    Runs BEFORE any ES modules load. Uses Bowser to detect unsupported browsers.
    The placeholder below is replaced at build time by Vite with the generated config.

    Note the loading bowser.js is synchronous (blocking) to ensure it is ready BEFORE we perform the checks.
    -->
  <script src="/bowser.js"></script>
  <script>
    (function () {
      var browser = bowser.getParser(window.navigator.userAgent);
      var isSupported = browser.satisfies({"chrome":">=109","firefox":">=149","edge":">=146","ios":">=16.6","opera":">=127","safari":">=17","samsung_internet":">=28"});

      if (isSupported === false) {
        var warning = document.getElementById("legacy-browser-warning");

        if (warning) {
          warning.classList.add("visible");
        }

        window.__LEGACY_BROWSER_BLOCKED__ = true;

        // Initialize Segment (ES5 compatible snippet) and track
        !function () { var i = "analytics", analytics = window[i] = window[i] || []; if (!analytics.initialize) if (analytics.invoked) window.console && console.error && console.error("Segment snippet included twice."); else { analytics.invoked = !0; analytics.methods = ["trackSubmit", "trackClick", "trackLink", "trackForm", "pageview", "identify", "reset", "group", "track", "ready", "alias", "debug", "page", "screen", "once", "off", "on", "addSourceMiddleware", "addIntegrationMiddleware", "setAnonymousId", "addDestinationMiddleware", "register"]; analytics.factory = function (e) { return function () { if (window[i].initialized) return window[i][e].apply(window[i], arguments); var n = Array.prototype.slice.call(arguments); if (["track", "screen", "alias", "group", "page", "identify"].indexOf(e) > -1) { var c = document.createElement("a"); c.href = location.href; n.push({ __t: "bpc", c: c.search, p: c.pathname, u: c.href, r: document.referrer }) } n.unshift(e); analytics.push(n); return analytics } }; for (var n = 0; n < analytics.methods.length; n++) { var key = analytics.methods[n]; analytics[key] = analytics.factory(key) } analytics.load = function (key, n) { var t = document.createElement("script"); t.type = "text/javascript"; t.async = !0; t.setAttribute("data-global-segment-analytics-key", i); t.src = "https://cdn.segment.com/analytics.js/v1/" + key + "/analytics.min.js"; var r = document.getElementsByTagName("script")[0]; r.parentNode.insertBefore(t, r); analytics._loadOptions = n }; analytics._writeKey = "DEQTBrk961iK7u7H9APfYirRWNIFLj0g"; analytics.SNIPPET_VERSION = "5.2.1"; analytics.load("DEQTBrk961iK7u7H9APfYirRWNIFLj0g"); } }();

        var browserInfo = browser.getBrowser();
        var osInfo = browser.getOS();

        analytics.track("legacy_browser_blocked", {
          browserName: browserInfo.name || "unknown",
          browserVersion: browserInfo.version || "unknown",
          osName: osInfo.name || "unknown",
          osVersion: osInfo.version || "unknown"
        });

        throw new Error("Unsupported browser");
      }
    })();
  </script>

  <!-- End App Setup -->

  <!-- Twitter Setup Script -->
  <script>
    window.twttr = (function (d, s, id) {
      var js,
        fjs = d.getElementsByTagName(s)[0],
        t = window.twttr || {};
      if (d.getElementById(id)) return t;
      js = d.createElement(s);
      js.id = id;
      js.crossOrigin = "anonymous";
      js.src = "https://platform.twitter.com/widgets.js";
      fjs.parentNode.insertBefore(js, fjs);
      t._e = [];
      t.ready = function (f) {
        t._e.push(f);
      };
      return t;
    })(document, "script", "twitter-wjs");
  </script>
  <!-- End Twitter Setup Script -->

  <!-- Google API Setup Script -->
  <script src="https://apis.google.com/js/api.js" crossorigin="anonymous"></script>
  <script type="text/javascript">
