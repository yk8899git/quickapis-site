  <!--
    Legacy Browser Warning Styles
    Matches the bootstrap loading screen design.
    Colors from harvest theme: canvas (#F9F1E4), text.contrast (#100F31)
    See docs/legacy-browser-support.md for more details.
    -->
  <style id="legacy-browser-styles">
    @font-face {
      font-family: "Ritual";
      font-style: normal;
      font-weight: 100 900;
      font-display: swap;
      src: url("/Ritual-VF.ttf") format("truetype");
    }

    #legacy-browser-warning {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999999;
      background: #f9f1e4;
      font-family:
        Ritual,
        -apple-system,
        BlinkMacSystemFont,
        "Segoe UI",
        Roboto,
        Helvetica,
        Arial,
        sans-serif;
    }

    #legacy-browser-warning.visible {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    #legacy-browser-warning img {
      margin-bottom: 28px;
    }

    #legacy-browser-warning h1 {
      margin: 0;
      font-size: 18px;
      font-weight: 500;
      line-height: 20px;
      color: #595959;
    }

    #legacy-browser-warning p {
      margin: 8px 0 0;
      max-width: 449px;
      font-size: 12px;
      font-weight: 300;
      line-height: 16px;
      color: #9c9c9c;
      text-align: center;
    }
  </style>

  <!-- Google Tag Manager -->
  <script>
    (function (w, d, s, l, i) {
      w[l] = w[l] || [];
      w[l].push({
