ld\",\"components\",\"v0\",\"shadcnui\"]},\"className\":\"hidden\",\"withAvatar\":true}]\ne6:[\"$\",\"$Lcc\",\"XmzC9oi7g4m-29\",{\"index\":29,\"showStatus\":false,\"template\":{\"blockId\":\"b_phObSXRKMzB\",\"description\":\"A minimal, high-performance eCommerce frontend fully integrated with Shopify.\\n\\nIt packs:\\n• Fast-loading pages optimized for conversion\\n• Seamless Shopify integration for live product data\\n• Clean, minimal design focused on the essentials\\n• Built-in cart and checkout flow\\n• Easy to customize and extend for your brand\\n• Drop it in, connect your store, and start selling with style and speed.\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/screenshots/XmzC9oi7g4m-RdoC3q5zJ279Ys2inplHhEtoT0t7S5.jpg\",\"title\":\"Shopify Ecommerce Template\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"XmzC9oi7g4m\",\"templateVersionId\":\"nMUBbtB78la\",\"uses\":2649,\"authorId\":\"ZNJvi2SET9uoaJJF75wa6XiN\",\"isTeamTemplate\":false,\"likeCount\":496,\"vercelDeploymentUrl\":null,\"ownerId\":\"ZNJvi2SET9uoaJJF75wa6XiN\",\"createdAt\":\"2025-09-19T21:03:09.405Z\",\"category\":\"ecommerce\",\"tags\":[\"ecommerce\",\"minimal\",\"furniture\"]},\"className\":\"hidden\",\"withAvatar\":true}]\ne7:[\"$\",\"$Lcc\",\"8QhCJAwn16K-30\",{\"index\":30,\"showStatus\":false,\"template\":{\"blockId\":\"b_XeJDbewTn7x\",\"description\":\"Launch your SaaS website with our shadcn/ui template. Professional, responsive, and ready to customize in v0.\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/v0%20thumbnail-hw4ZgeeGtGnGJVQ1naerPtZFXdFoAB.png\",\"title\":\"MindSpace - SaaS Landing Page Template\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"8QhCJAwn16K\",\"templateVersionId\":\"QSFyZv4rQp4\",\"uses\":1968,\"authorId\":\"oK1nhga4gLpy3fEn5FPS23Jf\",\"isTeamTemplate\":false,\"likeCount\":298,\"vercelDeploymentUrl\":null,\"ownerId\":\"oK1nhga4gLpy3fEn5FPS23Jf\",\"createdAt\":\"2025-09-11T12:18:08.435Z\",\"category\":\"landing-pages\",\"tags\":[\"shadcnui\",\"shadcn\",\"landing-page\",\"saas\",\"free\",\"orange\",\"carousel\",\"hero-section\",\"footer\"]},\"className\":\"hidden\",\"withAvatar\":true}]\ne8:[\"$\",\"$Lcc\",\"qlMs2yCd6MD-31\",{\"index\":31,\"showStatus\":false,\"template\":{\"blockId\":\"b_I5Tw0LTutJh\",\"description\":\"This is a sleek, two-column portfolio w"])</script><script>self.__next_f.push([1,"ebsite designed to showcase vision- and image-based projects. It features a dedicated About section and static pages for in-depth project explorations. Highly customizable, it allows you to seamlessly integrate your own tools and services.\\n\\nIf you find any bugs, please send it to studioneuwaes@gmail.com\",\"imageUrl\":\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/screenshots/dpl_3oXytRiPt6FP8jziwc3UePG24odS-IQJaObkbTvefmMqHFnsgNYRQV9PRpm.jpg\",\"title\":\"Design Portfolio\",\"publishedToCommunity\":\"rejected\",\"templateCanonId\":\"qlMs2yCd6MD\",\"templateVersionId\":\"OnrIswW4lsh\",\"uses\":670,\"authorId\":\"5kVRENFAkWKMoYnUflHk7nxM\",\"isTeamTemplate\":false,\"likeCount\":121,\"vercelDeploymentUrl\":null,\"ownerId\":\"5kVRENFAkWKMoYnUflHk7nxM\",\"createdAt\":\"2025-08-29T17:47:34.484Z\",\"category\":\"blog-and-portfolio\",\"tags\":[\"portfolio\",\"design\",\"art\",\"visual\",\"blog\",\"projects\",\"about\"]},\"className\":\"hidden\",\"withAvatar\":true}]\ne9:[\"$\",\"$Lcc\",\"6rnQUvOhgnB-32\",{\"index\":32,\"showStatus\":false,\"template\":{\"blockId\":\"b_9310LcrQkPY\",\"description\":\"Transform your space with KATACHI, where you can explore and purchase exquisite, handcrafted furniture designed for modern living. Effortlessly browse curated collections, view detailed product information, and enjoy a seamless shopping experience.\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/Screenshot%202025-08-18%20at%2011.23.26%201-qinzAJXLXRGRNuOkMO6MzF2hVjAEau.jpg\",\"title\":\"KATACHI\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"6rnQUvOhgnB\",\"templateVersionId\":\"dtlc0qPkKcU\",\"uses\":3123,\"authorId\":\"sgeDKOyvY41XAreXMDwcFJSG\",\"isTeamTemplate\":true,\"likeCount\":708,\"vercelDeploymentUrl\":null,\"ownerId\":null,\"createdAt\":\"2025-08-18T09:20:06.917Z\",\"category\":\"ecommerce\",\"tags\":[\"ecommerce\",\"design\",\"parallax\",\"gradient-blur\",\"landing-page\",\"modern\",\"typography\",\"bold\",\"collection\"]},\"className\":\"hidden\",\"withAvatar\":true}]\nea:[\"$\",\"$Lcc\",\"8Y9E0cStKrW-33\",{\"index\":33,\"showStatus\":false,\"template\":{\"blockId\":\"b_OZfBqAQhCES\",\"description\":\"Launch your SaaS website with our shadcn/ui template. Professional, responsive, and ready to customize in v0.\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/Frame%203-k1f3E8iDBhLDwixJZe5KsByveSePXb.png\",\"title\":\"Flowly - SaaS Landing Page Template\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"8Y9E0cStKrW\",\"templateVersionId\":\"toxGEcIpvua\",\"uses\":633,\"authorId\":\"oK1nhga4gLpy3fEn5FPS23Jf\",\"isTeamTemplate\":true,\"likeCount\":150,\"vercelDeploymentUrl\":null,\"ownerId\":null,\"createdAt\":\"2025-09-11T13:01:54.245Z\",\"category\":\"landing-pages\",\"tags\":[\"shadcn\",\"landing-page\",\"hero-section\",\"footer\",\"animated\",\"website\",\"template\"]},\"className\":\"hidden\",\"withAvatar\":true}]\nfc:T46c,The app is a fully featured Waitlist Template designed for startups and indie hackers to create and manage a waitlist for early adopters. It allows users to collect email addresses from potential customers and send personalized emails to subscribers, fostering engagement and excitement around their product or service. The app is built using Next.js, BaseHub, and Tailwind CSS, ensuring a modern and responsive user interface.\n\nKey features of the app include:\n- A customizable waitlist form for collecting email addresses.\n- Integration with BaseHub for managing waitlist data and sending newsletters.\n- The ability to send personalized emails to subscribers, enhancing user interaction.\n- A responsive design powered by Tailwind CSS, ensuring compatibility across devices.\n- One-click deployment options for easy setup on platforms like Vercel.\n- Local development support with clear instructions for setting up the environment.\n\nOverall, this app provides a comprehensive solution for managing waitlists and engaging with early adopters, making it an essential tool for startups looking to build anticipation for their products.eb:[\"$\",\"$Lcc\",\"VGs1Sc5BbGi-34\",{\"index\":34,\"showStatus\":false,\"template\":{\"blockId\":\"b_9ED4m5CZFpp\",\"description\":\"$fc\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/2-J"])</script><script>self.__next_f.push([1,"PnfFlqXC413i1MX7K1CBTnBy78gWO.jpg\",\"title\":\"Waitlist\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"VGs1Sc5BbGi\",\"templateVersionId\":\"FjPSIAwxWrw\",\"uses\":5798,\"authorId\":\"gzK156rumATJ2qOixRNjBE53\",\"isTeamTemplate\":false,\"likeCount\":279,\"vercelDeploymentUrl\":null,\"ownerId\":\"gzK156rumATJ2qOixRNjBE53\",\"createdAt\":\"2025-09-15T18:59:47.475Z\",\"category\":\"landing-pages\",\"tags\":[]},\"className\":\"hidden\",\"withAvatar\":true}]\nec:[\"$\",\"$Lcc\",\"XqrIezRilBR-35\",{\"index\":35,\"showStatus\":false,\"template\":{\"blockId\":\"b_kIIi8R6DBC6\",\"description\":\"\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/CleanShot%202025-02-06%20at%2016.27.08@2x-VTTj5u7Tn66hKqKXVegMNfw9rhf7BD.png\",\"title\":\"Glow menu component\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"XqrIezRilBR\",\"templateVersionId\":\"z1DJkx0UHJJ\",\"uses\":14302,\"authorId\":\"8e3L9Qum87FuzJ7vmaEvvGL0\",\"isTeamTemplate\":false,\"likeCount\":625,\"vercelDeploymentUrl\":null,\"ownerId\":\"8e3L9Qum87FuzJ7vmaEvvGL0\",\"createdAt\":\"2025-02-06T15:27:29.272Z\",\"category\":\"components\",\"tags\":[]},\"className\":\"hidden\",\"withAvatar\":true}]\nfd:T6c4,"])</script><script>self.__next_f.push([1,"This application is a multiplayer online social platform that allows users to interact in a virtual isometric environment. Users can create avatars, navigate through different rooms, engage in chat, and perform various actions such as dancing, sitting, waving, and laughing. The app features a music system where users can play chiptune tracks from music boxes located in the environment.\n\nTo use the app, users can enter a room, control their avatar using keyboard inputs or mouse clicks, and interact with other users in real-time. The chat functionality allows users to send messages, and commands can be issued to perform specific actions. The app also supports audio playback, with options to adjust volume and toggle sound on or off.\n\nThe application is built using modern web technologies, including TypeScript and React for the frontend, and utilizes hooks for state management and event handling. The isometric rendering of the environment is achieved through HTML5 canvas, allowing for smooth animations and interactions. The app also incorporates a pathfinding algorithm to enable avatar movement within the grid-based layout of the rooms.\n\nKey features of the app include:\n- Real-time multiplayer interactions with other users.\n- Customizable avatars that can perform various actions.\n- A chat panel for communication between users.\n- An isometric room layout with multiple environments to explore.\n- Music boxes that play chiptune tracks, with fallback audio options.\n- User-friendly controls for navigating and interacting with the environment.\n- A settings panel to adjust audio preferences.\n\nOverall, this app provides an engaging social experience in a virtual world, combining elements of gaming and communication."])</script><script>self.__next_f.push([1,"ed:[\"$\",\"$Lcc\",\"EYN85i0FdYV-36\",{\"index\":36,\"showStatus\":false,\"template\":{\"blockId\":\"b_dTAA7OSnwYn\",\"description\":\"$fd\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/Bildschirmfoto%202025-08-08%20um%2008.24.46-aTc2IFdJry61lsBuwBHeUM9wk8Eqb9.png\",\"title\":\"Habbo Hotel like Multiplayer Chatroom using GPT-5\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"EYN85i0FdYV\",\"templateVersionId\":\"Ey0WAMhQZcH\",\"uses\":2506,\"authorId\":\"6R8sDH45uxVEIUOYHNWOWY4a\",\"isTeamTemplate\":false,\"likeCount\":399,\"vercelDeploymentUrl\":null,\"ownerId\":\"6R8sDH45uxVEIUOYHNWOWY4a\",\"createdAt\":\"2025-08-08T14:18:11.652Z\",\"category\":\"apps-and-games\",\"tags\":[]},\"className\":\"hidden\",\"withAvatar\":true}]\nfe:T732,"])</script><script>self.__next_f.push([1,"The Tactical Dashboard is a web application designed for managing and monitoring tactical operations, agents, and intelligence activities. It provides a centralized interface for users to access various sections, including the Command Center, Agent Network, Operations, Intelligence, and Systems.\n\nTo use the app, users can navigate through a sidebar that allows them to switch between different sections. The sidebar can be collapsed for a more compact view. Each section contains relevant information and functionalities, such as agent status, mission details, and intelligence reports. Users can interact with various components, such as buttons for deploying agents, filtering data, and viewing detailed reports.\n\nThe app is built using React and TypeScript, leveraging modern web technologies for a responsive and dynamic user experience. It utilizes a component-based architecture, with reusable UI components for cards, buttons, inputs, and badges. The application also incorporates icons from the Lucide library for visual representation of different functionalities.\n\nKey features of the Tactical Dashboard include:\n- A collapsible sidebar for easy navigation between sections.\n- A Command Center that displays an overview of agent allocation and mission activity.\n- An Agent Network section for managing and monitoring field operatives, including search and filter capabilities.\n- An Operations section for planning and executing missions, with detailed progress tracking.\n- An Intelligence section for accessing classified reports and threat analysis.\n- A Systems section for monitoring infrastructure health and performance metrics.\n\nOverall, the Tactical Dashboard serves as a comprehensive tool for tactical operations management, providing users with the necessary insights and controls to effectively oversee their activities."])</script><script>self.__next_f.push([1,"ee:[\"$\",\"$Lcc\",\"v9Hg1dBb5o3-37\",{\"index\":37,\"showStatus\":false,\"template\":{\"blockId\":\"b_vCjl2X1Qo6H\",\"description\":\"$fe\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/screenshots/v9Hg1dBb5o3-lwCoO1sKwfOM4Ncli6yGOBqRy6wEMw.jpg\",\"title\":\"Cyberpunk dashboard design\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"v9Hg1dBb5o3\",\"templateVersionId\":\"oM7cNDpz7A0\",\"uses\":14726,\"authorId\":\"kKfuBXuc2NC3T9M6pjkdzR4q\",\"isTeamTemplate\":true,\"likeCount\":646,\"vercelDeploymentUrl\":null,\"ownerId\":null,\"createdAt\":\"2025-07-25T21:04:14.416Z\",\"category\":\"dashboards\",\"tags\":[]},\"className\":\"hidden\",\"withAvatar\":true}]\nef:[\"$\",\"$Lcc\",\"fnLkUW05eg3-38\",{\"index\":38,\"showStatus\":false,\"template\":{\"blockId\":\"b_p9nPLm9Czwl\",\"description\":null,\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/Screenshot%202025-03-05%20011737-bHT7NMHz8SaQWAEUMsKCaXgH4uf3Yz.png\",\"title\":\"Saas Landing Page\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"fnLkUW05eg3\",\"templateVersionId\":\"Z9xFQh2HhoT\",\"uses\":9547,\"authorId\":\"oBwA55aLGV7F0jJwVfGp4hJv\",\"isTeamTemplate\":true,\"likeCount\":381,\"vercelDeploymentUrl\":\"https://veek-saas-landing-page.vercel.app\",\"ownerId\":null,\"createdAt\":\"2025-03-05T00:18:01.040Z\",\"category\":\"landing-pages\",\"tags\":[]},\"className\":\"hidden\",\"withAvatar\":true}]\nff:T613,"])</script><script>self.__next_f.push([1,"This app is a contact form application that allows users to send messages via email. It is designed to facilitate communication between users and the application owner by collecting user input and sending it to a specified email address.\n\nTo use the app, users simply navigate to the contact page where they will find a form. The form requires users to input their email address and a message detailing their inquiry or feedback. Once the form is filled out, users can submit it by clicking the \"Send Message\" button. Upon submission, the app processes the input and sends an email containing the user's message to a predefined recipient address.\n\nThe app is built using TypeScript and React, leveraging the Next.js framework for server-side rendering and routing. It utilizes the Resend API for email delivery, which requires an API key and a recipient email address to be set as environment variables. The user interface is styled using Tailwind CSS, providing a modern and responsive design.\n\nKey features of the app include:\n- A user-friendly contact form that collects email addresses and messages.\n- Real-time feedback through toast notifications, informing users of successful submissions or errors.\n- A loading state for the submit button to enhance user experience during the email sending process.\n- Integration with the Resend service for reliable email delivery.\n- Responsive design that adapts to different screen sizes.\n\nOverall, this app serves as an effective tool for managing user inquiries and enhancing communication with the audience."])</script><script>self.__next_f.push([1,"f0:[\"$\",\"$Lcc\",\"z6bdmQDMgv5-39\",{\"index\":39,\"showStatus\":false,\"template\":{\"blockId\":\"b_cAoQAcDyC9C\",\"description\":\"$ff\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/resend-contact-form-86huX90Z8bwU9EPAe8AHq2yWEiHyF5.jpg\",\"title\":\"Resend Contact Form\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"z6bdmQDMgv5\",\"templateVersionId\":\"J2ZKxrPBF4v\",\"uses\":739,\"authorId\":\"9gZ3ITi99JO6PLh5ZAxjkgJj\",\"isTeamTemplate\":false,\"likeCount\":26,\"vercelDeploymentUrl\":null,\"ownerId\":\"9gZ3ITi99JO6PLh5ZAxjkgJj\",\"createdAt\":\"2025-08-06T16:09:46.252Z\",\"category\":\"components\",\"tags\":[]},\"className\":\"hidden\",\"withAvatar\":true}]\n100:T776,"])</script><script>self.__next_f.push([1,"This application is a customizable link-sharing platform designed to allow users to create a personal link page. Users can manage their profile information, including their name, bio, avatar, and verification status, as well as add, edit, and delete links to their favorite websites or social media profiles.\n\nTo use the app, users can toggle between edit and view modes. In edit mode, they can modify their profile details and manage their links through a user-friendly interface. The app provides real-time feedback on changes, allowing users to see how their profile will look as they make adjustments. Users can also customize the appearance of their link page by selecting different themes, background colors, patterns, and font styles.\n\nThe application is built using TypeScript and React, leveraging various hooks for state management and user interactions. It utilizes a combination of custom hooks for managing profile and link data, as well as UI components for rendering forms, buttons, and other interactive elements. The app also incorporates a theme provider to manage and apply user-selected themes and styles dynamically.\n\nKey features of the app include:\n- Profile management: Users can update their name, bio, avatar, and verification status.\n- Link management: Users can add, edit, and delete links, with validation for URL formats.\n- Theme customization: Users can choose from various color themes, background patterns, and font styles to personalize their link page.\n- Responsive design: The app is designed to be mobile-friendly, ensuring a seamless experience across devices.\n- Real-time notifications: Users receive feedback through toast notifications when actions are performed, such as saving changes or adding links.\n\nOverall, this application provides a comprehensive solution for users looking to create a personalized online presence through a customizable link-sharing platform."])</script><script>self.__next_f.push([1,"f1:[\"$\",\"$Lcc\",\"Zz6mBLdU9bC-40\",{\"index\":40,\"showStatus\":false,\"template\":{\"blockId\":\"b_ZysGpjYRaJ6\",\"description\":\"$100\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/CleanShot%202025-05-08%20at%2018.48.03%402x-vLmSaTZNFY1wCpMby2S36Ueh6EWMVl.png\",\"title\":\"v0.me\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"Zz6mBLdU9bC\",\"templateVersionId\":\"3LjDRWTgHKV\",\"uses\":2413,\"authorId\":\"Gn4IQx4PEIX3drZH0D9qN1AI\",\"isTeamTemplate\":true,\"likeCount\":95,\"vercelDeploymentUrl\":null,\"ownerId\":null,\"createdAt\":\"2025-08-05T20:38:45.954Z\",\"category\":\"apps-and-games\",\"tags\":[]},\"className\":\"hidden\",\"withAvatar\":true}]\nf2:[\"$\",\"$Lcc\",\"eboqyw0KGxu-41\",{\"index\":41,\"showStatus\":false,\"template\":{\"blockId\":\"b_OsKviRCD6d9\",\"description\":\"Frosted Authentication Page - Sign In and Sign Up UI Design\",\"imageUrl\":\"https://gvsmhepiuiax2e6y.public.blob.vercel-storage.com/templates/assets/1920-YOfkbz1GrIO6WZR1yYtPR6ManNhaqw.jpg\",\"title\":\"Frosted Authentication Page\",\"publishedToCommunity\":\"approved\",\"templateCanonId\":\"eboqyw0KGxu\",\"templateVersionId\":\"vA8SbvYIzL7\",\"uses\":2368,\"authorId\":\"Edhx10n5mi1hCxNlCRQpWTUZ\",\"isTeamTemplate\":false,\"likeCount\":501,\"vercelDeploymentUrl\":null,\"ownerId\":\"Edhx10n5mi1hCxNlCRQpWTUZ\",\"createdAt\":\"2025-08-13T06:33:17.723Z\",\"category\":\"compon