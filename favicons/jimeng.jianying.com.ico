:{"strength":0.6},"style_reference":{"strength":0.8}},"extra":{"model_source":"by Seedream 5.0 Lite","raw_model_source":"Seedream 5.0 Lite"},"feats_cant_combine":[],"model_bg_prompt_starling_key":"","resolution_map":{"2k":{"image_ratio_sizes":[{"ratio_type":1,"width":2048,"height":2048},{"ratio_type":2,"width":1728,"height":2304},{"ratio_type":3,"width":2560,"height":1440},{"ratio_type":4,"width":2304,"height":1728},{"ratio_type":5,"width":1440,"height":2560},{"ratio_type":6,"width":1664,"height":2496},{"ratio_type":7,"width":2496,"height":1664},{"ratio_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1810060580\u0026x-signature=xExloe7lAyAa4AGipmnSRAzEF%2BU%3D"},"prompt":"帮我生成图片：奇幻写实风格，神明世界里狂风呼啸，空间扭曲变形，巨手带着强大的气势降临，各样有形的气流顺着人物面对的方向汹涌而去，散发着丝丝杀意，风卷着残叶，仿佛要将面前的一切都摧毁，画面采用侧视角，以冷色调为主，增强画面的冲击力。动态模糊强化携带速度线残影，超广角强透视构图，动态模糊边缘虚化，强烈胶片颗粒与高噪点质感，弥散晕染的暗部层次，张力十足，压迫感，细节生动完美。\n威胁压迫感，极其震撼的一幕，光影彼此交织错杂的梦幻感，朦胧，过曝，双重曝光，电影级构图，视觉冲击，8K画质，超清，极致细节，极致刻画，清晰的线条，高对比。","sample_steps":16,"seed":463279631,"large_image_info":{"height":2560,"width":1440,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"0","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"帮我生成图片：奇幻写实风格，神明世界里狂风呼啸，空间扭曲变形，巨手带着强大的气势降临，各样有形的气流顺着人物面对的方向汹涌而去，散发着丝丝杀意，风卷着残叶，仿佛要将面前的一切都摧毁，画面采用侧视角，以冷色调为主，增强画面的冲击力。动态模糊强化携带速度线残影，超广角强透视构图，动态模糊边缘虚化，强烈胶片颗粒与高噪点质感，弥散晕染的暗部层次，张力十足，压迫感，细节生动完美。\n威胁压迫感，极其震撼的一幕，光影彼此交织错杂的梦幻感，朦胧，过曝，双重曝光，电影级构图，视觉冲击，8K画质，超清，极致细节，极致刻画，清晰的线条，高对比。","image_type":3},"statistic":{"usage_num":5,"favorite_num":149,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"aigc_draft":{"version":"3.0.2","uri":"aigc-draft/10891559780876","content":"{\"type\":\"draft\",\"id\":\"fe97b7fa-128d-4177-8ee3-47b1c5133ca1\",\