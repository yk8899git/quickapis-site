"ratio_type":7,"width":2496,"height":1664},{"ratio_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1810060580\u0026x-signature=xExloe7lAyAa4AGipmnSRAzEF%2BU%3D"},"prompt":"真实摄影，亚洲美少女薇薇身着浅色上衣，白色短裙，斜挎拼色包包，手持复古相机；站在临水栏杆旁，单手比耶，背景是都市建筑群（含高楼、山脉）与水面，整体风格休闲活力，充满城市滨水景观的氛围美感，倾斜构图，（电影级面光：1.6），（光线追踪：1.5），（冷白皮漫感质感的光滑皮肤：1.7），（人物有最好的骨相：1.2），（网感脸：1.6），身材完美，莫兰迪配色，高颜值网红，INS风，幼态脸，19岁女生尖下巴，三庭五眼比例均衡，身材娇小，细腻陶瓷水嫩肌肤，偏冷白皮，随机的妆容，随机的饰品，随机的动作，侧光，发丝轻飘，凌乱，随机角度拍摄，总体有很多的不确定性，但又好看，\n风格甜美少女系，氛围慵懒俏皮，东方美女，黑长直，年轻娇小，发丝呈现出自然的蓬松感与垂坠感，长发散落于肩头两侧，几缕发丝拂面，冷白皮气质美女，薇薇纯欲风，皮肤白皙，偶像气质，fairskin，气质的江南美女子，有点甜美，皮肤美白透亮，表情可爱，甜美氛围，细腻笔触，独特韵味的美，可爱表情","sample_steps":25,"large_image_info":{"height":2560,"width":1440,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"7592824151476358409","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"真实摄影，甜美少女系，INS风，莫兰迪配色，倾斜构图，电影级面光，光线追踪，冷白皮漫感质感，细腻陶瓷水嫩肌肤，偏冷白皮，fairskin。亚洲美少女薇薇，19岁，黑长直，长发散落肩头，几缕发丝拂面，自然蓬松垂坠，幼态脸，尖下巴，三庭五眼均衡，身材娇小，高颜值网红，东方美女，江南美女子，偶像气质，纯欲风，皮肤白皙透亮，细腻笔触，独特韵味，可爱表情，甜美氛围。身着浅色上衣，白色短裙，斜挎拼色包包，手持复古相机，站在临水栏杆旁，单手比耶，侧光，发丝轻飘凌乱，随机角度拍摄，随机妆容、饰品、动作，背景为都市建筑群（含高楼、山脉）与水面，城市滨水景观，休闲活力氛围，慵懒俏皮，皮肤美白透亮，表情可爱，甜美氛围，细腻笔触，独特韵味的美，可爱表情。","image_type":3},"statistic":{"usage_num":411,"favorite_num":364,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7592824151476358409","effect_id":"7592824151476358409","effect_type":9,"description":"","cover_url":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/b6829b15d42848b5a88121509dd9fea2~tplv-tb4s082cfz-aigc_resize:640:640.jpeg?lk3s=4fa96020\u0026x-expires=1810060584\u0026x-signature=EXqG9b4abDszDBAPM%2B269QKY7BI%3D","cover_url_map":null,"smart_crop_loc":null,"status":102,"title":""},"author":{"na