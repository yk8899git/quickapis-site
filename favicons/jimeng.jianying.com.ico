"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1810060580\u0026x-signature=BE5jEUDNeMT5UiYzxwg2sUiSl6M%3D"},"prompt":"伯莱塔92手枪的概念分解蓝图草图，在纯白色卡片背景上放置了一个超详细的3D渲染伯莱塔92手枪组件作为中心主题，以极广角，低视角的视角呈现，以产生强大的深度，戏剧性的规模压缩和视觉上令人惊叹的结构张力。主要结构元件包括枪管接收器、枪栓连动座、撞针、扳机组、弹匣盒、从动弹簧、黑色工程塑料枪托，所有这些都悬挂在精确对齐的轴向爆炸布局中，沿着主透视轴漂浮在空间中。主要渲染周围是密集的技术注释层：内部机械剖面图、螺栓循环轨迹图、后坐力方向箭头、装配序列流程图和材料标注。每个零件都标有毫米刻度的测量线，编号标签。","sample_steps":16,"seed":780460651,"large_image_info":{"height":2304,"width":1728,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"7595963803209190665","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"概念分解蓝图草图，超详细3D渲染，纯白色卡片背景，极广角低视角，强大深度，戏剧性规模压缩，视觉结构张力。中心主题为伯莱塔92手枪组件，包括枪管接收器、枪栓连动座、撞针、扳机组、弹匣盒、从动弹簧、黑色工程塑料枪托，悬挂于精确对齐的轴向爆炸布局，沿主透视轴漂浮空间。周围密集技术注释层：内部机械剖面图、螺栓循环轨迹图、后坐力方向箭头、装配序列流程图、材料标注。每个零件带毫米刻度测量线与编号标签。","image_type":3},"statistic":{"usage_num":12,"favorite_num":107,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7595963803209190665","effect_id":"7595963803209190665","effect_type":9,"description":"","cover_url":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/47732234b08e4f908bb375f794bc6063~tplv-tb4s082cfz-aigc_resize:640:640.jpeg?lk3s=4fa96020\u0026x-expires=1810060584\u0026x-signature=S3LQxPjMiYdj%2FVz7%2FMBSVyp6sWE%3D","cover_url_map":null,"smart_crop_loc":null,"status":102,"title":""},"author":{"name":"Dr.Mopp","avatar_url":"https://p6-faceu-img-sign.byteimg.com/tos-cn-i-tb4s082cfz/d3fbe0965b25451387f84e174ede0278~tplv-resize:200:200.webp?lk3s=4eecb9e8\u0026x-expires=1781116584\u0026x-signature=BuzbC0Yhawkgl6rPm19mI5JQ9fI%3D","uid":"2870151187283031","sec_uid":"MS4wLjABAAAAciHi-_BoK8lL14jhFBa4hTtp5LUCt75Aa391-L6cPeQQlDCKGxnkkYoKsgQTEQfb","description":"FUNN.Design ","has_followed":false,"followed_req_uid":false,"status":0,"account_type":0},"feature":"","extra":{"template_type":"ima