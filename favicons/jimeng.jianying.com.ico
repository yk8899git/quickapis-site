空正脸，神秘气质，华丽炫酷花纹与质感，暖色调，美轮美奂的诡异氛围，危险恐惧与惊艳迷人交织，极致细节刻画，立体纹理，奢华繁琐恢弘大气，超高清画质。底部中间标注英文小字\"ALIENX STUDIO\"，古典巴洛克风格与极繁主义叙事融合。","image_type":3},"statistic":{"usage_num":53,"favorite_num":601,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7601029309502950682","effect_id":"7601029309502950682","effect_type":9,"description":"","cover_url":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/5d998f2775ea45f5ba6485aedcde568c~tplv-tb4s082cfz-aigc_resize:640:640.jpeg?lk3s=4fa96020\u0026x-expires=1810060584\u0026x-signature=4e7M07jrmvvdtv5oOLFtL4DRrZo%3D","cover_url_map":null,"smart_crop_loc":null,"status":102,"title":"感谢提示词老哥，大圣真帅"},"author":{"name":"Popsicool","avatar_url":"https://p3-faceu-img-sign.byteimg.com/tos-cn-i-tb4s082cfz/6a160e05f25e458aaadfb2a9d5b06155~tplv-resize:200:200.webp?lk3s=4eecb9e8\u0026x-expires=1781116584\u0026x-signature=vTOsDuF0nMZEnqF6eIXY8QkO9Rc%3D","uid":"1264916322609836","sec_uid":"MS4wLjABAAAA9aZz3CqZSCSWgOfj7VbSNl_aILW31xLCo5ZQ2uW-haJUZhKtzgnxjj92FrN_ReHV","description":"","has_followed":false,"followed_req_uid":false,"status":0,"account_type":0},"feature":"","extra":{"template_type":"image","ai_feature":"text_generate_image"}},"comment_info":{"link_comment_id":"7603252674067989273"},"aigc_draft":{"version":"3.0.2","uri":"aigc-draft/8103860519436","content":"{\"type\":\"draft\",\"id\":\"f4983b73-dc4c-48b3-835e-829ef03c5a0f\",\"min_version\":\"3.0.2\",\"min_features\":[],\"is_from_tsn\":true,\"version\":\"3.0.2\",\"main_component_id\":\"5295e4eb-1f63-4f6f-a0c3-e861bd9ad4aa\",\"component_list\":[{\"type\":\"image_base_component\",\"id\":\"5295e4eb-1f63-4f6f-a0c3-e861bd9ad4aa\",\"min_version\":\"3.0.2\",\"aigc_mode\":\"workbench\",\"gen_type\":1,\"metadata\":{\"type\":\"\",\"id\":\"f7609ada-cbba-44ac-b09f-f709466aaaee\",\"created_platform\":2,\"created_platform_version\":\"2061600\",\"created_time_in_ms\":\"1770319053254\",\"created_did\":\"\"},\"generate_type\":\"generate\",\"abilities\":{\"ty