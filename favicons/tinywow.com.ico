        border-bottom: none;
    }
    .mobile_menu li a {
        position: relative;
        padding: 17px 16px;
    }
    .mobile_menu li a::after {
        position: absolute;
        right: 0;
        top: 9px;
        color: #707375;
    }
    .menu2>li>ul {
        position: relative;
        width: 100%;
        -webkit-box-shadow: none;
        box-shadow: none;
        opacity: 1;
        visibility: visible;
        padding: 0;
        border-radius: 0;
    }
    .multilavel>ul {
        top: 0px;
        left: 0px;
        position: relative;
        -webkit-box-shadow: none;
        box-shadow: none;
        border-radius: 0px;
        padding: 0;
        background-color: #fafbfb;
        width: 100%;
        visibility: visible;
        opacity: 1;
        display: none;
        -webkit-transition: unset;
        -o-transition: unset;
