    .mobile_menu {
        position: fixed;
        top: 0;
        left: -100%;
        z-index: 1019;
        height: 100dvh;
        width: 100%;
        background-color: #fff;
        overflow-y: auto;
        overflow-x: hidden;
        -webkit-transition: 0.4s;
        -o-transition: 0.4s;
