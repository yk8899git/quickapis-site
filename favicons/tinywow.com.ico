    }
    .mobile_menu.current {
        left: 0;
    }
    .mobile_menu .menu2 {
        -webkit-box-orient: vertical;
        -webkit-box-direction: normal;
        -ms-flex-direction: column;
        flex-direction: column;
        -webkit-box-align: start;
        -ms-flex-align: start;
        align-items: flex-start;
        margin-bottom: -16px;
    }
    .mobile_menu .menu2>li {
        width: 100%;
    }
    .mobile_menu .menu2>li>a {
