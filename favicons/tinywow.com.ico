}

.collage-grid_item {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

.collage-grid_item .image-progress {
    width: 100%;
    height: 32px;
    top: calc(50% - 16px);
    position: absolute;
    z-index: 7;
}

.collage-grid_item .image-progress .container-progress {
    width: 60%;
    margin: 0 auto;
}

/* end simple color picker for charts */

