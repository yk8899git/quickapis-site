}

.file-drop-area {
    margin-top: unset;
    border: none;
    border-radius: unset;
}

.file-drop-area.hidden-area {
    width: 100%;
    height: 100%;
    padding: 0;
}

.file-drop-area.hidden-area .file-uploads.button {
    width: 100%;
    height: 100%;
}

.file-drop-area.hidden-area .file-uploads.button label {
