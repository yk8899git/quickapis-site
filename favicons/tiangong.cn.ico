  <script>
    (function () {
      try {
        var time = Date.now();
        var blob = new Blob(["blob test"], { type: "text/html" });
        var url = URL.createObjectURL(blob);
        var iframe = document.createElement("iframe");
        iframe.style.display = "none";
        iframe.src = url;
        var loaded = false;
        window.__blob_supported = false;
        function cleanup() {
          URL.revokeObjectURL(url);
          document.body.removeChild(iframe);
          clearTimeout(timeout);
        }
        iframe.onload = () => {
          loaded = true;
          cleanup();
          window.__blob_supported = true;
          // console.log("iframe loaded", Date.now() - time);
        };
        document.body.appendChild(iframe);
        var timeout = setTimeout(() => {
          if (!loaded) {
            cleanup();
            window.__blob_supported = false;
          }
        }, 500);

        var time2 = Date.now();
        var srcDoc = "<div>srcdoc test</div>";
        var iframe2 = document.createElement("iframe");
        iframe2.style.display = "none";
        iframe2.srcdoc = srcDoc;
        var loaded2 = false;
        window.__srcdoc_supported = false;
        function cleanup2() {
          document.body.removeChild(iframe2);
          clearTimeout(timeout2);
        }
        iframe2.onload = () => {
          loaded2 = true;
          cleanup2();
          window.__srcdoc_supported = true;
          // console.log("iframe loaded2", Date.now() - time2);
        };
        document.body.appendChild(iframe2);
        var timeout2 = setTimeout(() => {
          if (!loaded2) {
            cleanup2();
            window.__srcdoc_supported = false;
          }
        }, 500);
      } catch (e) {
        console.log(e);
        window.__blob_supported = false;
        window.__srcdoc_supported = false;
      }
    })();
  </script>
  
  <script>
      // arms ignore只提供错误的message， 例如: time is not defined
      // 并没提供错误的堆栈信息，无法定位到浏览器插件的错误文件
      // 所以在之前拦截错误，阻止事件上报
      window.addEventListener("error", function (error) {
        var __error_stack_keywords_path = ["chrome-extension:"];
        var found = false;
        for (var i = 0; i < __error_stack_keywords_path.length; i++) {
          if (error && error.error && error.error.stack && error.error.stack.indexOf(__error_stack_keywords_path[i]) !== -1) {
            found = true;
            break;
          }
        }
        if (found) {
          error.stopImmediatePropagation();
        }
      });
      function __isSafariOrIOS() {
        var userAgent = navigator.userAgent;
        var isIOS = /iPhone|iPad|iPod/.test(userAgent);
        var isSafari = /^((?!chrome|android|crios|fxios).)*safari/i.test(userAgent);
        return isIOS || isSafari;
      }

      window.__bl = {
          config: {
            pid:"in9gwarca6@fcbe9bb0e7e5810",
            appType:"web",
            imgUrl:"https://arms-retcode.aliyuncs.com/r.png?",
            sendResource:true,
            enableLinkTrace:true,
            behavior:true,
            useFmp:true,
            enableSPA:true,
            ignore: {
              ignoreApis: [
                function(str) {   // 方法
                    if (str && str.indexOf('agents_api/abtest/user/ab_exps') >= 0) {
                        return true;   // 不上报
                    }
                    return false;      // 上报
                },
              ],
              ignoreErrors: [
                function(str) {
                  // safari/ios fetch错误会导致arms调用t: api 和 t: error上报，触发unhandledrejection
                  if (str === "Load failed" && __isSafariOrIOS()) {
                    return true;
                  }
                  return false;
                },
              ],
            },
            autoSendPerf:true,
            environment:"prod",
          },
      };
  </script>
  <script type="text/javascript" src="https://retcode.alicdn.com/retcode/bl.js" crossorigin></script>
  
    <div id="loadingBox">
      <img id="loadingImg" src="https://static.tiangong.cn/fe/skywork-site-assets/images/home/loading.gif">
      <p id="loadingText"></p>
    </div>
    <script>
      const getLanguage = () => {
        const userPersist = window.localStorage.getItem("userPersist");
        const lang = JSON.parse(userPersist)?.userSettingConfig?.language;
        let text = "Loading";
        if (lang === "zh") {
          text = "加载中";
        } else if (lang === "en") {
          text = "Loading";
        } else if (lang === "ja") {
          text = "読み込み中";
        } else if (lang === "es") {
          text = "Cargando";
        } else if (lang === "zh-hant") {
          text = "加載中";
        } else if (lang === "ko") {
          text = "로딩 중";
        } else if (lang === "de") {
          text = "Lädt";
        } else if (lang === "fr") {
          text = "Chargement";
        };
        document.getElementById("loadingText").innerHTML = text;
      }
      getLanguage();
      const getTheme = () => {
        // 检查当前路径是否是发票页面，如果是则强制使用浅色主题
        const currentPath = window.location.pathname;
        const isRequestInvoicePage = currentPath.startsWith("/request-invoice");
        if (isRequestInvoicePage) {
          return false; // 发票页面强制浅色
        }

        const themeMode = window.localStorage.getItem("__theme_mode__");
        let isDark = false;
        if (themeMode === "1") {
          isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        } else if (themeMode === "2") {
          isDark = false;
        } else if (themeMode === "3") {
          isDark = true;
        }
        return isDark;
      };
      document.getElementById("loadingBox").style.backgroundColor = getTheme() ? "#181D24" : "#F7F8FA";
      document.getElementById("loadingText").style.color = getTheme() ? "#EBEBEB" : "#485568";
    </script>
    <div id="app">
    </div>
    
    
    
