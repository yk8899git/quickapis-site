    function compareVersion(currentVersion, compare) {
      var list1 = compare.split('.').map(function(i){return parseInt(i)});
      var list2 = currentVersion.split('.').map(function(i){return parseInt(i)})
      var a1 = list1[0];
      var b1 = list1[1];
      var c1 = list1[2];
      var a2 = list2[0];
      var b2 = list2[1];
      var c2 = list2[2];
    
      if (currentVersion === compare) {
        return 0;
      }
    
      var r =
        a2 > a1 || (a1 === a2 && b2 > b1) || (a1 === a2 && b1 === b2 && c2 > c1);
    
      return r ? 1 : -1;
    };
  
    
    function getAppVersion () {
      var userAgent = navigator.userAgent;
      var CommonMatch = userAgent.match(/TONGYI\/(\d+\.\d+\.\d+)/);
      if (CommonMatch) {
        return CommonMatch[1];
      }
      var iOSMatch = userAgent.match(/Tongyi4iPhone\/(\d+\.\d+\.\d+)/);
      if (iOSMatch) {
        return iOSMatch[1];
      }
      var iOSMatch2 = userAgent.match(/TongyiApp\/(\d+\.\d+\.\d+)/);
      if (iOSMatch2) {
        return iOSMatch2[1];
      }
      var androidMatch = userAgent.match(/tongyi\/(\d+\.\d+\.\d+)/);
      if (androidMatch) {
        return androidMatch[1];
      }
      return '';
    };

    var APP_VERSION = getAppVersion();
    var inTYAPP = !!APP_VERSION;
  

    function waitForBody(cb) {
      if (document.body) {
        cb();
      } else {
        requestAnimationFrame(function() {
          waitForBody(cb);
        });
      }
    };
  </script><script type="text/javascript">
  var lock = false;
  var lockReload = false;
  var element = document.createElement('div');

  function addTips() {
    if (!document.body) {
      return;
    }

    if (lock) {
      return;
    }

    lock = true;

    function reload() {
      if (lockReload) {
        return;
      }

      lockReload = true;

      checkNetWork()
        .then(function() {
          window.location.reload();
        })
        .catch(function() {
          lockReload = false;
        })
    }

    element.innerHTML = '<div id="tips" style="position: fixed; width: 100%; height: 100%; left: 0; top: 0; display: flex; justify-content: center; align-items: center; flex-direction: column;background: transparent; font-size: 0.8rem; color: #8F91A8">网络异常，试试刷新<div id="network-error-btn" style="background: linear-gradient(68deg, #615CED 0%, #3E2FA7 180%);height: 2rem; border-radius: 2rem; line-height: 2rem; text-align: center; color: #FFFFFF; font-size: 0.7rem; margin-top: 2rem; padding: 0px 2.2rem;">刷新</div></div>'
    document.body.appendChild(element);
    document.querySelector('#ice-container').style.display = 'none';
    document.body.style.background = 'transparent';
    
    element.querySelector('#network-error-btn').addEventListener('click', reload);
  };

  function checkNetWork() {
    return new Promise(function(resolve, reject) {
      fetch('https://gw.alicdn.com/imgextra/i2/O1CN017YzZdE1le96yrYRsl_!!6000000004843-55-tps-36-63.svg?t=' + Date.now(), {
        method: 'HEAD',
        cache: 'no-cache'
      })
      .then(function(res) {
        if (res.ok) {
          resolve(true);
        }
        else {
          reject('addResourceLoadHandler network error');
        }
      })
      .catch(function() {
        reject('addResourceLoadHandler network error');
      });
    });
  }

  window.addEventListener('error', function(e) {
    if (!(e instanceof ErrorEvent)) {
      var target = e.target;
      var isRequire = target.hasAttribute('resource-require');
      if (isRequire) {
        if (inTYAPP && compareVersion(APP_VERSION, '3.11.0') >= 0 && window.WindVane) {
          window.WindVane.call('ty', 'showErrorPage', {
              title: "未知错误",
              content: "千问前方拥堵中，晚点再来试试看",
              buttonContent: "重试",
          });
        }
        else {
          waitForBody(function() {
            addTips();
          });
        }
      }
    }
  }, true);

