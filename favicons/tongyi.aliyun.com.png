    window.aesSendApi = function() {};
    if (window.AESPluginAPI) {
      window.aesSendApi = aes.use(AESPluginAPI, {
        sendResponseOnSuccess: true,
      }).sendApi;
    }

    window.aesSendEvent = function() {};
    if (window.AESPluginEvent) {
