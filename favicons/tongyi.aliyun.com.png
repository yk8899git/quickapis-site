    }

    if (window.AESPluginBlank) {
      window.aes.use(AESPluginBlank, {
        plugin_blank_target: '#ice-container',
        plugin_blank_when: ['error', 'timeout', 'leave'],
        plugin_blank_tester: function(target) {
          if (target) {
            if (target.children.length === 0) return false;
            return true;
          } else {
            return false;
          }
        }
      });
    }
    
    if (window.AESPluginPV) {
      window.aes.use(AESPluginPV);
    }

