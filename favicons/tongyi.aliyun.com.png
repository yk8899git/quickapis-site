            c1: a.host,
            c2: src,
          });
        }
        catch(e) {
          console.error(e);
        }
      }
    }, true)

    window.addEventListener('unhandledrejection', function(e) {
      var info = e.reason;
  
      if (info instanceof Error) {
        aesSendError(info);
      } else if (info) {
        var traceId = info.traceId;
        var errorCode = info.errorCode;
        var data = info.data;
        
        delete info.traceId;
        delete info.errorCode;
        delete info.data;
  
        try {
          info = typeof info === 'string' ? info : JSON.stringify(info);
        } catch (e) {
          info = 'JSON.stringify error';
        }
  
        aesSendError({
          type: 'rejection_error',
          message: info,
        });
  
        if (traceId || errorCode || data) {
          aesSendEvent('rejection_error', {
            et: 'OTHER',
            c1: errorCode,
            c2: traceId,
            c3: data ? JSON.stringify(data) : '',
          });
        }
      } else {
        aesSendError({
          type: 'rejection_error',
          message: info,
        });
      }
    });
