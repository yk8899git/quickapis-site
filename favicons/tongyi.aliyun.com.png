      window.aes.use(AESPluginEventTiming);
    }

    if (window.AESPluginLongTask) {
      window.aes.use(AESPluginLongTask);
    }

    if (window.AESPluginAnimFluency) {
      window.aes.use(AESPluginAnimFluency);
    }

    window.aesSendError = function() {};
    if (window.AESPluginJSError) {
      window.aesSendError = aes.use(AESPluginJSError, {
        disable_unhandled_rejection: true,
