    }

    window.addEventListener('error', function(e) {
      if (!(e instanceof ErrorEvent)) {
        var target = e.target;
        var src = target.src || target.href;
        if(!src || src.indexOf('.mmstat.com') !== -1 || /aes-d+.cn-wulanchabu.log.aliyuncs.com/.test(src)){
