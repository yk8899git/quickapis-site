    performance.mark('render-start');
    window.aes = new window.AES({pid: 'HstAjZ', requiredFields: ["uid"]});

    if (window.AESPluginResourceError) {
      window.aes.use(AESPluginResourceError);
    }

    if (window.AESPluginAutolog) {
      window.aes.use(AESPluginAutolog);
